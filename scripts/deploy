#!/bin/bash

set -e

project_name="job-listing"


# Update system
sudo apt update

# Install go
if ! command -v go &> /dev/null; then
    echo "📦 Installing Go..."
    sudo snap install go --classic
fi

# Clone repository if not present
if [ ! -d "$HOME/job-listing" ]; then
    echo "📥 Cloning repository..."
    git clone https://github.com/LionelPinheiroDuarte/${project_name}.git
    cd ${project_name}
    git fetch --all
    git switch dev
else
    echo "📥 Updating repository..."
    cd ${project_name}
    git pull
fi

# Build application
echo "🔨 Building application..."
go build -o main

# Setup deployment directory
echo "📂 Setting up /opt/${project_name}..."
sudo mkdir -p /opt/${project_name}
sudo cp main /opt/${project_name}/
sudo cp data.json /opt/${project_name}/
sudo cp index.html /opt/${project_name}/
sudo cp -r static /opt/${project_name}/ 2>/dev/null || true
sudo chmod +x /opt/${project_name}/main


# Create user if not exists
if ! id appuser &> /dev/null; then
    echo "👤 Creating appuser..."
    sudo useradd -r -s /bin/false appuser
fi

sudo chown -R appuser:appuser /opt/${project_name}

# Restart service
echo "🔄 restarting service..."
sudo systemctl restart ${project_name}
sudo systemctl enable ${project_name}

# Check status
echo "✅ Deployment complete!"
sudo systemctl status ${project_name} --no-pager

echo ""
echo "🌐 Application available at http://$(curl -s ifconfig.me):8000"