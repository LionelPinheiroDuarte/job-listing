services:
  app:
    build:
      context: ..
      dockerfile: Dockerfile
    container_name: job-listing-app
    ports:
      - "8000:8000"
    environment:
      - PORT=8000
      - LOG_LEVEL=${LOG_LEVEL:-info}
      - ENVIRONMENT=${APP_ENV:-development}
    volumes:
      - ../data.json:/app/data.json:ro
    healthcheck:
      test:
        [
          "CMD",
          "wget",
          "--no-verbose",
          "--tries=1",
          "--spider",
          "http://localhost:8000/health",
        ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 512M
        reservations:
          cpus: "0.25"
          memory: 256M
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    networks: # ← Référence aux networks (juste le nom)
      - app-network
      - monitoring-network
    labels:
      com.job-listing.service: "backend"
      com.job-listing.version: "1.0.0"

  prometheus:
    image: prom/prometheus:latest
    container_name: job-listing-prometheus
    ports:
      - "9090:9090"
    volumes:
      - ../monitoring:/etc/prometheus:ro
      - prometheus_data:/prometheus
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--web.enable-lifecycle"
      - "--storage.tsdb.retention.time=15d"
    user: "nobody"
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "0.3"
          memory: 512M
        reservations:
          cpus: "0.1"
          memory: 256M
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
    networks: # ← Référence aux networks (juste le nom)
      - monitoring-network
    depends_on:
      app:
        condition: service_healthy
    labels:
      com.job-listing.service: "monitoring"

networks: # ← DÉFINITION des networks (niveau racine)
  app-network:
    driver: bridge
    name: job-listing-app
  monitoring-network:
    driver: bridge
    name: job-listing-monitoring

volumes: # ← Niveau racine aussi
  prometheus_data:
    name: job-listing-prometheus-data
